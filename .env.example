# ============================================================
#  MẪU BIẾN MÔI TRƯỜNG — copy sang .env rồi điền giá trị thật
# ============================================================

# Chuỗi bí mật ký JWT/cookie của Payload. Bắt buộc.
# Sinh mới: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-a-long-random-string

# Kết nối SQLite (file cục bộ). Khi deploy giữ file này trên volume bền vững.
DATABASE_URI=file:./ddn.db

# Domain thật của site — dùng cho canonical URL, thẻ hreflang, sitemap.xml.
# Local để http://localhost:3000 ; production đổi thành https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- SMTP để gửi email thông báo RFQ tới salesEmail ---
# Nếu để TRỐNG: đơn RFQ vẫn được lưu vào Inquiries, email chỉ log ra console (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Địa chỉ hiển thị ở trường "From" (vd: "DDN Charcoal <no-reply@your-domain.com>")
SMTP_FROM=
