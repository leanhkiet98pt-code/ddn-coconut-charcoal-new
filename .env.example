# ============================================================
#  MẪU BIẾN MÔI TRƯỜNG — copy sang .env rồi điền giá trị thật.
#  Trên Vercel: nhập các biến này trong Project → Settings → Environment Variables.
# ============================================================

# Chuỗi bí mật ký JWT/cookie của Payload. Bắt buộc.
# Sinh mới: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

# --- Database: Postgres (Neon) ---
# Connection string Postgres. Neon: lấy ở Dashboard → Connection Details (bật "Pooled connection").
# Dạng: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URI=

# --- Media storage: Vercel Blob ---
# Token đọc/ghi Blob. Vercel: Storage → tạo Blob store → copy BLOB_READ_WRITE_TOKEN.
# Để TRỐNG khi dev không có token => media tạm lưu local disk (chỉ dùng local).
BLOB_READ_WRITE_TOKEN=

# Domain thật của site — dùng cho canonical, hreflang, sitemap, serverURL, CSRF/CORS.
# Local: http://localhost:3000 ; production: https://your-domain.com (KHÔNG dấu / ở cuối)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- SMTP gửi email thông báo RFQ tới salesEmail ---
# Để TRỐNG: đơn RFQ vẫn lưu, email chỉ log ra console (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Địa chỉ hiển thị ở trường "From" (vd: "DDN Charcoal <no-reply@your-domain.com>")
SMTP_FROM=

# --- Đẩy lead sang Google Sheet qua webhook Make.com ---
# Dán URL webhook của scenario Make (Make lo phần ghi Google Sheet — app KHÔNG giữ credential Google).
# Để TRỐNG => bỏ qua bước đẩy Sheet, site vẫn chạy bình thường.
MAKE_WEBHOOK_URL=
